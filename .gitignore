# ==========================================================
# Homelab07
# Git Ignore
# ==========================================================

# This file intentionally remains minimal.
# Ignore rules will grow only as the project evolves.

# ------------------------------------------------------------------------------
# macOS
# ------------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride

# ------------------------------------------------------------------------------
# Visual Studio Code
# ------------------------------------------------------------------------------
.vscode/
.history/

# ------------------------------------------------------------------------------
# JetBrains IDEs
# ------------------------------------------------------------------------------
.idea/

# ------------------------------------------------------------------------------
# Logs
# ------------------------------------------------------------------------------
*.log
logs/

# ------------------------------------------------------------------------------
# Temporary files
# ------------------------------------------------------------------------------
*.tmp
*.temp
*.bak
*.old
*.orig
*.swp
*~

# ------------------------------------------------------------------------------
# Environment variables
# ------------------------------------------------------------------------------
.env
.env.*
!.env.example

# ------------------------------------------------------------------------------
# Private information (never committed)
# ------------------------------------------------------------------------------
private/

# ------------------------------------------------------------------------------
# Certificates
# ------------------------------------------------------------------------------
*.crt
*.csr
*.key
*.pem
*.p12
*.pfx

# ------------------------------------------------------------------------------
# SSH Keys
# ------------------------------------------------------------------------------
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub

# ------------------------------------------------------------------------------
# Local configuration
# ------------------------------------------------------------------------------
*.local
*.local.*
