# HomeLab07 OwnCloud example configuration.
# Copy this file to:
#   ../HomeLab07.private/env/owncloud.env
#
# Never commit the real .env file.

# Absolute mount path for the Rockstor share named homelab07-data.
HOMELAB07_DATA_ROOT=/path/to/homelab07-data

# Public OwnCloud endpoint.
# Use placeholders in Git and keep real domains only in HomeLab07.private.
OWNCLOUD_DOMAIN=cloud.example.com
OWNCLOUD_TRUSTED_DOMAINS=cloud.example.com
OWNCLOUD_OVERWRITE_CLI_URL=https://cloud.example.com
OWNCLOUD_OVERWRITE_PROTOCOL=https
OWNCLOUD_TRUSTED_PROXIES=homelab07-nginx-proxy-manager

# OwnCloud application database.
OWNCLOUD_DB_HOST=homelab07-mariadb
OWNCLOUD_DB_NAME=owncloud
OWNCLOUD_DB_USERNAME=owncloud
OWNCLOUD_DB_PASSWORD=replace-with-a-strong-password
OWNCLOUD_DB_PREFIX=oc_
OWNCLOUD_DB_CHARSET=utf8mb4
OWNCLOUD_DB_COLLATION=replace-with-validated-owncloud-collation

# Initial OwnCloud administrator.
# These values are applied only during first initialization.
OWNCLOUD_ADMIN_USERNAME=admin
OWNCLOUD_ADMIN_PASSWORD=replace-with-a-strong-admin-password

# Shared Valkey platform service.
OWNCLOUD_REDIS_HOST=homelab07-valkey
