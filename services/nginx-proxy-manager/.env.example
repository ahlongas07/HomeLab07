# HomeLab07 Nginx Proxy Manager example configuration.
# Copy this file to:
#   ../HomeLab07.private/env/nginx-proxy-manager.env
#
# Never commit the real .env file.

# Absolute mount path for the Rockstor share named homelab07-data.
HOMELAB07_DATA_ROOT=/path/to/homelab07-data

# Nginx Proxy Manager application database.
NPM_DB_HOST=homelab07-mariadb
NPM_DB_PORT=3306
NPM_DB_NAME=npm_db
NPM_DB_USER=npm_user
NPM_DB_PASSWORD=replace-with-a-strong-password
