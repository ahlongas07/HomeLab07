# Copy to ../HomeLab07.private/env/paperless-ngx.env and replace placeholders.
# Never commit the real environment file.

PAPERLESS_ROOT=/path/to/homelab07-paperless
PAPERLESS_URL=https://paperless.example.com
PAPERLESS_TIME_ZONE=Region/City
PAPERLESS_SECRET_KEY=replace-with-a-long-random-secret

PAPERLESS_DB_HOST=homelab07-mariadb
PAPERLESS_DB_PORT=3306
PAPERLESS_DB_NAME=paperless
PAPERLESS_DB_USERNAME=paperless
PAPERLESS_DB_PASSWORD=replace-with-a-strong-password
PAPERLESS_DB_CHARSET=utf8mb4
PAPERLESS_DB_COLLATION=utf8mb4_unicode_ci

PAPERLESS_REDIS_URL=redis://homelab07-valkey:6379/1
PAPERLESS_REDIS_PREFIX=paperless

PAPERLESS_UID=1000
PAPERLESS_GID=1000
PAPERLESS_OCR_LANGUAGE=spa+eng
PAPERLESS_CONSUMER_POLLING=60
PAPERLESS_WEBSERVER_WORKERS=1
PAPERLESS_TASK_WORKERS=1
PAPERLESS_THREADS_PER_WORKER=1
