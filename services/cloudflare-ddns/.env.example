# HomeLab07 Cloudflare Dynamic DNS example configuration.
# Copy this file to:
#   ../HomeLab07.private/env/cloudflare-ddns.env
#
# Never commit the real .env file.

# Cloudflare API token with DNS edit permissions for the target zone.
CLOUDFLARE_API_TOKEN=replace-with-cloudflare-api-token

# Canonical DNS record managed by HomeLab07.
# Additional public services should normally use CNAME records pointing here.
# Use placeholders in Git and keep real domains only in HomeLab07.private.
CLOUDFLARE_DDNS_DOMAINS=home.example.com

# New DNS records should be proxied through Cloudflare by default.
CLOUDFLARE_DDNS_PROXIED=true

# HomeLab07 currently manages IPv4 DNS updates only.
CLOUDFLARE_DDNS_IP6_PROVIDER=none

# Increase detection timeout for networks with occasional latency.
CLOUDFLARE_DDNS_DETECTION_TIMEOUT=10s
