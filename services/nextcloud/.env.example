# HomeLab07 Nextcloud PoC example configuration.
# Copy this file to:
#   ../HomeLab07.private/env/nextcloud.env
#
# Never commit the real environment file.

# Dedicated Rockstor share. The html and data directories must already exist.
NEXTCLOUD_ROOT=/path/to/homelab07-nextcloud

# Public endpoint. Keep real domains only in HomeLab07.private.
NEXTCLOUD_TRUSTED_DOMAINS=nextcloud.example.com
# Obtain the private proxy-network CIDR with the command documented in README.
NEXTCLOUD_TRUSTED_PROXIES=replace-with-proxy-network-cidr
NEXTCLOUD_OVERWRITE_HOST=nextcloud.example.com
NEXTCLOUD_OVERWRITE_PROTOCOL=https
NEXTCLOUD_OVERWRITE_CLI_URL=https://nextcloud.example.com

# Independent Nextcloud database on the shared MariaDB service.
NEXTCLOUD_DB_HOST=homelab07-mariadb
NEXTCLOUD_DB_NAME=nextcloud
NEXTCLOUD_DB_USERNAME=nextcloud
NEXTCLOUD_DB_PASSWORD=replace-with-a-strong-password

# Consumed only by operation/nextcloud-db-create.sh.
NEXTCLOUD_DB_CHARSET=utf8mb4
NEXTCLOUD_DB_COLLATION=utf8mb4_general_ci

# Initial administrator. Applied only during first initialization.
NEXTCLOUD_ADMIN_USERNAME=admin
NEXTCLOUD_ADMIN_PASSWORD=replace-with-a-strong-admin-password

# Shared Valkey platform service.
NEXTCLOUD_REDIS_HOST=homelab07-valkey
NEXTCLOUD_REDIS_PORT=6379

# Runtime limits for the PoC; tune only from private configuration.
NEXTCLOUD_PHP_MEMORY_LIMIT=512M
NEXTCLOUD_PHP_UPLOAD_LIMIT=16G
