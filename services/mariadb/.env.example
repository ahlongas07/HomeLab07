# HomeLab07 MariaDB example configuration.
# Copy this file to:
#   ../HomeLab07.private/env/mariadb.env
#
# Never commit the real .env file.

# Absolute mount path for the Rockstor share named homelab07-data.
HOMELAB07_DATA_ROOT=/path/to/homelab07-data

# MariaDB root bootstrap credential.
MARIADB_ROOT_PASSWORD=replace-with-a-strong-root-password
